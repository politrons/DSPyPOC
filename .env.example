# Databricks authentication
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<your-databricks-pat>

# DSPy compiler model (Databricks provider)
DSPY_COMPILER_MODEL=databricks/databricks-llama-4-maverick

# Optional only if using a custom OpenAI-compatible gateway
DSPY_API_BASE=
DSPY_API_KEY=

# Unity Catalog destination
UC_MODEL_NAME=<catalog>.<schema>.dspy_hf_context_poc
ENDPOINT_NAME=dspy-hf-context-poc-endpoint

# Optional local RAG chunk artifact
RAG_CHUNKS_PATH=data/knowledge_base_chunks.jsonl
